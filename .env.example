# Database Configuration
POSTGRES_DB=coinguard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# Spring DataSource
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/coinguard
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_postgres_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_at_least_256_bits_long
JWT_EXPIRATION=3600000
# JWT Access Token expiration: 3600000ms = 1 hour
JWT_REFRESH_EXPIRATION=604800000
# JWT Refresh Token expiration: 604800000ms = 7 days

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Email Configuration (Gmail SMTP)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_specific_password
SPRING_MAIL_PROTOCOL=smtp
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# File Upload
FILE_UPLOAD_DIR=./uploads/receipts

# Gemini AI Configuration
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
GEMINI_API_KEY=your_gemini_api_key_here
